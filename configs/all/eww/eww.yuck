          (label :class "${cal_d34_cls}" :halign "center" :hexpand true :text "${cal_d34}"))
        (box :orientation "h" :space-evenly true :halign "fill"
          (label :class "${cal_d35_cls}" :halign "center" :hexpand true :text "${cal_d35}")
          (label :class "${cal_d36_cls}" :halign "center" :hexpand true :text "${cal_d36}")
          (label :class "${cal_d37_cls}" :halign "center" :hexpand true :text "${cal_d37}")
          (label :class "${cal_d38_cls}" :halign "center" :hexpand true :text "${cal_d38}")
          (label :class "${cal_d39_cls}" :halign "center" :hexpand true :text "${cal_d39}")
          (label :class "${cal_d40_cls}" :halign "center" :hexpand true :text "${cal_d40}")
          (label :class "${cal_d41_cls}" :halign "center" :hexpand true :text "${cal_d41}"))))))

;; -- Emoji Picker (rofi-emoji style with literal) --

(defwidget emoji-content []
  (box :class "emoji-overlay" :orientation "v" :halign "center" :valign "center"
    (eventbox :onclick "eww close emoji"
      (box :class "emoji-backdrop"))
    (box :class "emoji-card" :orientation "v" :space-evenly false
      (box :class "emoji-search" :orientation "h" :space-evenly false :spacing 8
        (label :class "emoji-search-icon" :text "")
        (label :class "emoji-search-text" :halign "start" :hexpand true
          :text {emoji_query == "" ? "Search emoji..." : emoji_query}))
      (box :class "emoji-separator")
      (literal :class "emoji-list" :content emoji_listen))))

;; -- App Launcher (rofi drun, gross-style with literal) --

(defwidget launcher-content []
  (box :class "launcher-overlay" :orientation "v" :halign "center" :valign "center"
    (eventbox :onclick "scripts/toggle-launcher"
      (box :class "launcher-backdrop"))
    (box :class "launcher-card" :orientation "v" :space-evenly false
      (box :class "launcher-search" :orientation "h" :space-evenly false :spacing 8
        (label :class "launcher-search-icon" :text "󰍉")
        (label :class "launcher-search-text" :halign "start" :hexpand true
          :text {search_query == "" ? "Type to search..." : search_query}))
      (box :class "launcher-separator")
      (literal :class "launcher-list" :content search_listen))))

;; -- Power Menu Widget --

(defwidget powermenu-content []
  (box :class "powermenu-overlay" :orientation "v" :halign "center" :valign "center"
    :space-evenly false
    (eventbox :onclick "scripts/toggle-powermenu"
      (box :class "powermenu-backdrop" :orientation "v"))
    (box :class "powermenu-card" :orientation "v" :space-evenly false :spacing 24 :halign "center"
      (label :class "powermenu-title" :text "Power Menu")
      (box :class "powermenu-actions" :orientation "h" :space-evenly false :spacing 16 :halign "center"
        (powermenu-button :icon "󰤄" :label "Sleep" :action "systemctl suspend")
        (powermenu-button :icon "󰍃" :label "Logout" :action "scripts/logout-session")
        (powermenu-button :icon "󰜉" :label "Reboot" :action "systemctl reboot")
        (powermenu-button :icon "⏻" :label "Power" :action "systemctl poweroff"))
      (button :class "powermenu-cancel" :onclick "scripts/toggle-powermenu"
        (label :text "Cancel")))))

(defwidget powermenu-button [icon label action]
  (button :class "powermenu-btn" :onclick "${action} && scripts/toggle-powermenu"
    (box :class "powermenu-btn-inner" :orientation "v" :space-evenly false :spacing 8 :halign "center"
      (label :class "powermenu-btn-icon" :text "${icon}")
      (label :class "powermenu-btn-label" :text "${label}"))))

;; ==========================================
;;  Eww Configuration - Main
;;  Variables, Polls, and Window Definitions
;; ==========================================

;; -- Variables --
(deflisten current_ws :initial "1"
  "scripts/getcurrentws")
(defvar show_date false)
(defvar powermenu_open false)
(defvar launcher_offset 0)
(defvar search_query "")
(defvar emoji_query "")
(defvar app_count 0)

;; Calendar
(defvar cal_month_name "July")
(defvar cal_year "2026")
(defvar cal_today "0")
(defvar cal_month_num "7")
(defvar cal_d0 "") (defvar cal_d1 "") (defvar cal_d2 "") (defvar cal_d3 "")
(defvar cal_d4 "") (defvar cal_d5 "") (defvar cal_d6 "") (defvar cal_d7 "")

;; -- Bar Widget --

(defwidget bar []
  (centerbox :class "bar" :orientation "h"
    (left)
    (center)
    (right)))

(defwidget left []
  (box :class "container workspaces" :orientation "h" :space-evenly false :spacing 4
    (ws-button :num 1)
    (ws-button :num 2)
    (ws-button :num 3)
    (ws-button :num 4)
    (ws-button :num 5)
    (ws-button :num 6)))

(defwidget ws-button [num]
  (button :class "ws {current_ws == num ? 'active' : occupied_ws.contains(concat(' ', to_string(num), ' ')) ? 'occupied' : ''}"
          :onclick "xdotool key super+${num}"
    "${num}"))

(defwidget center []
  (box :class "container music" :orientation "h" :halign "center"
    {music != "" ? "   ${music}" : ""}))

(defwidget right []
  (box :class "container tray" :orientation "h" :space-evenly false :spacing 8 :halign "end"
    (volume-pill)
    (cpu-pill)
    (ram-pill)
    (clock-pill)))

(defwidget volume-pill []
  (box :class "pill" :orientation "h" :space-evenly false :spacing 6
    (button :class "icon-btn" :onclick "scripts/setvol mute"
      {volume == 0 ? "󰝟" : "󰕾"})
    (progress :value "volume" :max 100)))

(defwidget cpu-pill []
  (box :class "pill" :orientation "h" :space-evenly false :spacing 6
    (label :class "icon" :text "󰍛")
    (progress :value "cpu" :max 100)))

(defwidget ram-pill []
  (box :class "pill" :orientation "h" :space-evenly false :spacing 6
    (label :class "icon" :text "󰈖")
    (progress :value "EWW_RAM.used_mem_perc" :max 100)))

(defwidget clock-pill []
  (eventbox :onclick "scripts/toggle-calendar"
    (box :class "pill clock-pill" :orientation "h" :space-evenly false :spacing 4
      (label :class "icon" :text "󰥔")
      (label :class "time-label" :text time)
      (label :class "date-label" :text {show_date ? date : ""}))))

;; -- Calendar Widget --

(defwidget calendar-content []
  (box :class "calendar-overlay" :orientation "v" :halign "end" :valign "begin"
    :space-evenly false
    (eventbox :onclick "scripts/toggle-calendar"
      (box :class "calendar-backdrop" :orientation "v"))
    (box :class "calendar-card" :orientation "v" :space-evenly false :spacing 8
      (box :class "calendar-header" :orientation "h" :space-evenly false :halign "fill"
        (button :class "calendar-nav" :onclick "scripts/calendar-nav prev ${cal_month_num} ${cal_year}"
          (label :text "󰅁"))
        (label :class "calendar-title" :halign "center" :hexpand true
          :text "${cal_month_name} ${cal_year}")
        (button :class "calendar-nav" :onclick "scripts/calendar-nav next ${cal_month_num} ${cal_year}"
          (label :text "󰅂"))
        (button :class "calendar-close" :onclick "scripts/toggle-calendar"
          (label :text "󰅖")))
      (box :class "calendar-weekdays" :orientation "h" :space-evenly true :halign "fill"
        (label :halign "center" :hexpand true :text "Mo")
        (label :halign "center" :hexpand true :text "Tu")
        (label :halign "center" :hexpand true :text "We")
        (label :halign "center" :hexpand true :text "Th")
        (label :halign "center" :hexpand true :text "Fr")
        (label :halign "center" :hexpand true :text "Sa")
        (label :halign "center" :hexpand true :text "Su"))
      (box :class "calendar-days" :orientation "v" :space-evenly true :halign "fill"
        (box :orientation "h" :space-evenly true :halign "fill"
          (label :class "${cal_d0_cls}" :halign "center" :hexpand true :text "${cal_d0}")
          (label :class "${cal_d1_cls}" :halign "center" :hexpand true :text "${cal_d1}")
          (label :class "${cal_d2_cls}" :halign "center" :hexpand true :text "${cal_d2}")
          (label :class "${cal_d3_cls}" :halign "center" :hexpand true :text "${cal_d3}")
          (label :class "${cal_d4_cls}" :halign "center" :hexpand true :text "${cal_d4}")
          (label :class "${cal_d5_cls}" :halign "center" :hexpand true :text "${cal_d5}")
          (label :class "${cal_d6_cls}" :halign "center" :hexpand true :text "${cal_d6}"))
        (box :orientation "h" :space-evenly true :halign "fill"
          (label :class "${cal_d7_cls}" :halign "center" :hexpand true :text "${cal_d7}")
          (label :class "${cal_d8_cls}" :halign "center" :hexpand true :text "${cal_d8}")
          (label :class "${cal_d9_cls}" :halign "center" :hexpand true :text "${cal_d9}")
          (label :class "${cal_d10_cls}" :halign "center" :hexpand true :text "${cal_d10}")
          (label :class "${cal_d11_cls}" :halign "center" :hexpand true :text "${cal_d11}")
          (label :class "${cal_d12_cls}" :halign "center" :hexpand true :text "${cal_d12}")
          (label :class "${cal_d13_cls}" :halign "center" :hexpand true :text "${cal_d13}"))
        (box :orientation "h" :space-evenly true :halign "fill"
          (label :class "${cal_d14_cls}" :halign "center" :hexpand true :text "${cal_d14}")
          (label :class "${cal_d15_cls}" :halign "center" :hexpand true :text "${cal_d15}")
          (label :class "${cal_d16_cls}" :halign "center" :hexpand true :text "${cal_d16}")
          (label :class "${cal_d17_cls}" :halign "center" :hexpand true :text "${cal_d17}")

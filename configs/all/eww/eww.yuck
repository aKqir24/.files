(defvar cal_d40 "") (defvar cal_d41 "")
(defvar cal_d0_cls "calendar-day") (defvar cal_d1_cls "calendar-day") (defvar cal_d2_cls "calendar-day") (defvar cal_d3_cls "calendar-day")
(defvar cal_d4_cls "calendar-day") (defvar cal_d5_cls "calendar-day") (defvar cal_d6_cls "calendar-day") (defvar cal_d7_cls "calendar-day")
(defvar cal_d8_cls "calendar-day") (defvar cal_d9_cls "calendar-day") (defvar cal_d10_cls "calendar-day") (defvar cal_d11_cls "calendar-day")
(defvar cal_d12_cls "calendar-day") (defvar cal_d13_cls "calendar-day") (defvar cal_d14_cls "calendar-day") (defvar cal_d15_cls "calendar-day")
(defvar cal_d16_cls "calendar-day") (defvar cal_d17_cls "calendar-day") (defvar cal_d18_cls "calendar-day") (defvar cal_d19_cls "calendar-day")
(defvar cal_d20_cls "calendar-day") (defvar cal_d21_cls "calendar-day") (defvar cal_d22_cls "calendar-day") (defvar cal_d23_cls "calendar-day")
(defvar cal_d24_cls "calendar-day") (defvar cal_d25_cls "calendar-day") (defvar cal_d26_cls "calendar-day") (defvar cal_d27_cls "calendar-day")
(defvar cal_d28_cls "calendar-day") (defvar cal_d29_cls "calendar-day") (defvar cal_d30_cls "calendar-day") (defvar cal_d31_cls "calendar-day")
(defvar cal_d32_cls "calendar-day") (defvar cal_d33_cls "calendar-day") (defvar cal_d34_cls "calendar-day") (defvar cal_d35_cls "calendar-day")
(defvar cal_d36_cls "calendar-day") (defvar cal_d37_cls "calendar-day") (defvar cal_d38_cls "calendar-day") (defvar cal_d39_cls "calendar-day")
(defvar cal_d40_cls "calendar-day") (defvar cal_d41_cls "calendar-day")

;; App launcher
(defpoll search_listen :interval "1s"
  "cat ~/.config/eww/scripts/search_items.txt 2>/dev/null || echo '(box)'" )

;; Emoji picker
(defpoll emoji_listen :interval "1s"
  "cat ~/.config/eww/scripts/emoji_items.txt 2>/dev/null || echo '(box)'" )

;; -- Polls --
(deflisten music :initial ""
  "playerctl --follow metadata --format '{{ artist }} - {{ title }}' 2>/dev/null || echo ''")

(defpoll volume :interval "1s"
  "scripts/getvol")

(defpoll cpu :interval "2s"
  "scripts/getcpu")

(defpoll occupied_ws :interval "3s"
  "scripts/getoccupied")

(defpoll time :interval "1s"
  "date '+%I:%M %p'")

(defpoll date :interval "1s"
  "LC_ALL=C date '+%b %-d, %Y'")

(defpoll cal_init :interval "86400s" "scripts/calendar && echo ok")
(defpoll app_cache_init :interval "86400s" "scripts/cache-apps && echo ok")

;; -- Windows --
(defwindow bar
  :monitor 0
  :windowtype "dock"
  :stacking "fg"
  :wm-ignore false
  :geometry (geometry :x "0%"
                      :y "4px"
                      :width "100%"
                      :height "26px"
                      :anchor "top center")
  :reserve (struts :side "top" :distance "36px")
  (bar))

(defwindow powermenu
  :monitor 0
  :windowtype "normal"
  :stacking "overlay"
  :wm-ignore true
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "100%"
                      :height "100%"
                      :anchor "top left")
  :reserve (struts :distance "0px" :side "top")
  (powermenu-content))

(defwindow calendar
  :monitor 0
  :windowtype "normal"
  :stacking "overlay"
  :wm-ignore true
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "100%"
                      :height "100%"
                      :anchor "top left")
  :reserve (struts :distance "0px" :side "top")
  (calendar-content))

(defwindow launcher
  :monitor 0
  :windowtype "normal"
  :stacking "overlay"
  :wm-ignore true
  :focusable true
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "100%"
                      :height "100%"
                      :anchor "top left")
  :reserve (struts :distance "0px" :side "top")
  (launcher-content))

(defwindow emoji
  :monitor 0
  :windowtype "normal"
  :stacking "overlay"
  :wm-ignore true
  :geometry (geometry :x "0%"
                      :y "0%"
                      :width "100%"
                      :height "100%"
                      :anchor "top left")
  :reserve (struts :distance "0px" :side "top")
  (emoji-content))


#!/bin/bash
EWW_DIR="$HOME/.config/eww"
WIDGETS="$EWW_DIR/widgets"
CACHE="$HOME/.cache/matugen/eww-colors.scss"
SCSS_OUT="$EWW_DIR/eww.scss"
YUCK_OUT="$EWW_DIR/eww.yuck"

# -- SCSS: colors + widget partials (alphabetical) --
{
    if [ -f "$CACHE" ]; then
        cat "$CACHE"
        echo ""
    fi
    for f in "$WIDGETS"/_*.scss; do
        [ -f "$f" ] && cat "$f" && echo ""
    done
} | sed 's/─/-/g; s/—/--/g; s/━/=/g; s/│/|/g; s/├/+/g; s/┐/>/g; s/┌/</g' > "$SCSS_OUT"

# -- Yuck: widget definitions first, then base (variables + windows) --
{
    for f in "$WIDGETS"/*.yuck; do
        fname=$(basename "$f")
        [ "$fname" != "base.yuck" ] && [ -f "$f" ] && cat "$f" && echo ""
    done
    [ -f "$WIDGETS/base.yuck" ] && cat "$WIDGETS/base.yuck" && echo ""
} | sed 's/─/-/g; s/—/--/g; s/━/=/g; s/│/|/g; s/├/+/g; s/┐/>/g; s/┌/</g' > "$YUCK_OUT"

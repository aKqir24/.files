#!/bin/sh
### BEGIN INIT INFO
# Provides:          power-profiles-daemon
# Required-Start:    $remote_fs $syslog dbus
# Required-Stop:     $remote_fs $syslog dbus
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Power Profiles daemon
# Description:       Manages power profiles (performance, balanced, power-saver)
### END INIT INFO

NAME="power-profiles-daemon"
DAEMON="/usr/libexec/power-profiles-daemon"
PIDFILE="/run/power-profiles-daemon.pid"

. /lib/lsb/init-functions

do_start() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        log_warning_msg "$NAME is already running."
        return 1
    fi
    log_daemon_msg "Starting $NAME"
    start-stop-daemon --start --quiet --background \
        --make-pidfile --pidfile "$PIDFILE" \
        --exec "$DAEMON"
    RETVAL=$?
    log_end_msg $RETVAL
    return $RETVAL
}

do_stop() {
    if [ ! -f "$PIDFILE" ] || ! kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        log_warning_msg "$NAME is not running."
        rm -f "$PIDFILE"
        return 1
    fi
    log_daemon_msg "Stopping $NAME"
    start-stop-daemon --stop --quiet --pidfile "$PIDFILE"
    RETVAL=$?
    rm -f "$PIDFILE"
    log_end_msg $RETVAL
    return $RETVAL
}

do_status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        log_success_msg "$NAME is running (PID $(cat "$PIDFILE"))."
        return 0
    else
        log_failure_msg "$NAME is not running."
        return 3
    fi
}

case "$1" in
    start)   do_start ;;
    stop)    do_stop ;;
    restart|force-reload)
        do_stop
        sleep 1
        do_start
        ;;
    status)  do_status ;;
    *)
        echo "Usage: $0 {start|stop|restart|force-reload|status}" >&2
        exit 3
        ;;
esac

exit 0
